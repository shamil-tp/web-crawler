<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>N-jin Search</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #ffffff;
            --fg: #111827;
            --accent: #4f46e5; /* Vibrant indigo */
            --muted: #6b7280;
            --border: #e5e7eb;
            --focus: #4f46e5;
            --logo-blend: multiply;
            --img-invert: 0;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #030712;
                --fg: #f9fafb;
                --accent: #818cf8; /* Lighter indigo for dark mode */
                --muted: #9ca3af;
                --border: #1f2937;
                --focus: #818cf8;
                --logo-blend: screen;
                --img-invert: 1;
            }
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: var(--bg);
            color: var(--fg);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        a {
            color: var(--fg);
            text-decoration: none;
        }

        /* Typography */
        h1, h2, h3 {
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.2;
        }

        p {
            font-size: 1rem;
            color: var(--muted);
        }

        /* Logo Styling */
        .logo-text {
            font-size: 4rem;
            font-weight: 800;
            letter-spacing: -0.05em;
            color: var(--fg);
            text-transform: lowercase;
        }

        .logo-img {
            max-width: 200px;
        }

        .logo-mini-text {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: var(--fg);
            text-transform: lowercase;
        }

        .logo-mini-img {
            height: 32px;
        }

        /* Forms */
        .search-form {
            width: 100%;
            max-width: 640px;
            margin: 0 auto;
        }

        .search-group {
            display: flex;
            align-items: center;
            border: 2px solid var(--border);
            border-radius: 8px;
            background: var(--bg);
            padding: 0.5rem;
            transition: all 0.2s;
        }

        .search-group:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.2);
        }

        .search-input {
            flex: 1;
            border: none;
            background: transparent;
            font-size: 1.125rem;
            font-family: inherit;
            padding: 0.75rem 1rem;
            color: var(--fg);
            outline: none;
        }

        .search-input::placeholder {
            color: #999;
        }

        .btn {
            background: var(--accent);
            color: #ffffff;
            border: none;
            border-radius: 6px;
            padding: 0.75rem 1.5rem;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        }

        /* Layouts */
        .home-layout {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            text-align: center;
        }

        .header {
            border-bottom: 1px solid var(--border);
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            gap: 2rem;
            position: sticky;
            top: 0;
            background: var(--bg);
            z-index: 10;
        }

        .header .search-form {
            margin: 0;
            max-width: 720px;
        }

        .header .search-group {
            border-width: 1px;
            padding: 0.25rem;
        }

        .header .search-input {
            padding: 0.5rem 1rem;
            font-size: 1rem;
        }

        .header .btn {
            padding: 0.5rem 1rem;
        }

        .main-content {
            max-width: 720px;
            margin: 3rem auto;
            padding: 0 2rem;
        }

        @media (min-width: 1024px) {
            .main-content {
                margin-left: 10%;
                margin-right: auto;
            }
        }

        /* Results */
        .stats {
            font-size: 0.875rem;
            color: var(--muted);
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .result-item {
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--border);
        }

        .result-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .result-url {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.875rem;
            color: var(--fg);
            margin-bottom: 0.25rem;
        }

        .favicon {
            width: 16px;
            height: 16px;
            filter: grayscale(100%) invert(var(--img-invert));
        }

        .result-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--fg);
            display: inline-block;
            margin-bottom: 0.5rem;
            text-decoration: underline;
            text-decoration-color: transparent;
            transition: text-decoration-color 0.2s;
        }

        .result-title:hover {
            text-decoration-color: var(--accent);
            color: var(--accent);
        }

        .result-snippet {
            font-size: 0.9375rem;
            color: var(--muted);
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Highlighting */
        mark, .highlight {
            background-color: var(--accent);
            color: #ffffff;
            padding: 0 0.3em;
            border-radius: 4px;
            font-weight: 600;
        }

        /* Pagination */
        .pagination {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border);
        }

        .page-link {
            font-weight: 600;
            color: var(--fg);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.5rem 1rem;
            transition: all 0.2s;
        }

        .page-link:hover {
            border-color: var(--accent);
            background: var(--accent);
            color: #ffffff;
        }

        .page-info {
            font-size: 0.875rem;
            color: var(--muted);
        }

        /* No Results */
        .no-results {
            padding: 3rem 0;
        }

        .no-results h2 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                align-items: stretch;
                padding: 1rem;
                gap: 1rem;
            }
            .main-content {
                padding: 0 1rem;
                margin-top: 2rem;
            }
        }
    </style>
</head>
<body>

    <% if (!results) { %>
        <!-- Home Page -->
        <main class="home-layout">
            <div style="margin-bottom: 2rem;">
                <% if (typeof logoPath !== 'undefined' && logoPath) { %>
                    <h1 class="logo-text">n-jin.</h1>
                <% } else { %>
                    <img src="/logo/logo.png" alt="N-jin Logo" class="logo-img">
                <% } %>
            </div>

            <form action="/search" method="GET" class="search-form">
                <div class="search-group">
                    <input 
                        type="text" 
                        name="q"
                        class="search-input"
                        placeholder="Search..."
                        required 
                        autofocus 
                        autocomplete="off">
                    <button type="submit" class="btn">Search</button>
                </div>
            </form>
        </main>

    <% } else { %>
        <!-- Results Page -->
        <header class="header">
            <a href="/" style="display: block;">
                <% if (typeof logoPath !== 'undefined' && logoPath) { %>
                    <div class="logo-mini-text">n-jin.</div>
                <% } else { %>
                    <img src="/logo/logo.png" alt="N-jin" class="logo-mini-img">
                <% } %>
            </a>

            <form action="/search" method="GET" class="search-form">
                <div class="search-group">
                    <input 
                        type="text" 
                        name="q" 
                        class="search-input" 
                        value="<%= query %>" 
                        required 
                        autocomplete="off">
                    <button type="submit" class="btn">Search</button>
                </div>
            </form>
        </header>

        <main class="main-content">
            <div class="stats">
                <%= totalResults.toLocaleString() %> results for <span class="highlight"><%= query %></span>
            </div>

            <% if (results.length === 0) { %>
                <div class="no-results">
                    <h2>No matches</h2>
                    <p>Your search <span class="highlight"><%= query %></span> did not match any documents.</p>
                </div>
            <% } else { %>
                <div class="results-list">
                    <% results.forEach(site => { %>
                        <article class="result-item">
                            <div class="result-url">
                                <% if (site.favicon) { %>
                                    <img src="<%= site.favicon %>" alt="" class="favicon" onerror="this.style.display='none'">
                                <% } %>
                                <span><%= site.url.replace(/^https?:\/\//, '').replace(/\/$/, '') %></span>
                            </div>
                            
                            <a href="<%= site.url %>">
                                <h3 class="result-title"><%= site.title %></h3>
                            </a>
                            
                            <p class="result-snippet">
                                <% if (site.description) { %>
                                    <%= site.description %>
                                <% } else { %>
                                    <%= site.content.substring(0, 180) %>...
                                <% } %>
                            </p>
                        </article>
                    <% }) %>
                </div>

                <nav class="pagination">
                    <% if (currentPage > 1) { %>
                        <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= currentPage - 1 %>" class="page-link">
                            &larr; Prev
                        </a>
                    <% } %>
                    
                    <span class="page-info"><%= currentPage %> / <%= totalPages %></span>

                    <% if (currentPage < totalPages) { %>
                        <a href="/search?q=<%= encodeURIComponent(query) %>&page=<%= currentPage + 1 %>" class="page-link">
                            Next &rarr;
                        </a>
                    <% } %>
                </nav>
            <% } %> 
        </main>
    <% } %>

</body>
</html>
